# ================================================================
# Hallucination Loop — 環境設定
# このファイルを .env にコピーして値を設定してください
# ================================================================

# ── Colab GPU サーバー（画像生成 + 3D生成）─────────────────────
# colab_server.ipynb を Colab で実行すると表示される URL
# 設定すると FLUX.1-schnell (img gen) + TripoSR (3D gen) が使われる
COLAB_SERVER_URL=https://xxxx-xxxx.trycloudflare.com

# ── Google Gemini API（画像分析）────────────────────────────────
# 無料取得: https://aistudio.google.com/app/apikey
# 無料枠: 15 req/min, 1M tokens/day
# 設定すると Replicate を使わず直接 Gemini API を呼び出す
GEMINI_API_KEY=your_gemini_api_key_here

# ── Blender ──────────────────────────────────────────────────────
# Blender 実行ファイルのパス（デフォルト: blender）
BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 4.3\blender.exe

# ── 出力ディレクトリ ─────────────────────────────────────────────
OUTPUT_DIR=outputs

# ── Replicate API（フォールバック）──────────────────────────────
# COLAB_SERVER_URL / GEMINI_API_KEY が未設定の場合のみ使用
# REPLICATE_API_TOKEN=your_replicate_token_here
